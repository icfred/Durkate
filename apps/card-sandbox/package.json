{
  "name": "@durak/card-sandbox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "deploy": "pnpm build && wrangler pages deploy dist --project-name=card-sandbox --branch=main --commit-dirty=true"
  },
  "dependencies": {
    "@durak/engine": "workspace:^",
    "@durak/skins-spike": "workspace:^",
    "@durak/ui": "workspace:^",
    "pixi.js": "^8.18.1"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@types/node": "^25.6.0",
    "happy-dom": "^20.9.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
